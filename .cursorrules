# -----------------------------------------------------------------------------
# SECTION 1: PROJECT IDENTITY
# -----------------------------------------------------------------------------

Project name:    FitNepal
Type:            Cross-platform fitness platform (mobile-first, web, desktop)
Target market:   Nepal (primary), South Asia (v2+), global (v3+)
Business model:  Freemium SaaS -- Free / Pro (NPR 499/mo) / Elite (NPR 1499/mo)
Current phase:   MVP -- 4-week solo build
Architecture:    Monorepo with shared types and services across platforms


# -----------------------------------------------------------------------------
# SECTION 2: FULL TECHNOLOGY STACK
# -----------------------------------------------------------------------------

## 2.1 Mobile (primary platform)
Runtime:         React Native 0.76 + Expo SDK 52
Language:        TypeScript 5.6 (strict mode, no exceptions)
Navigation:      React Navigation v7 (native stack + bottom tabs)
State:           Zustand 5 (global/UI state) + TanStack Query v5 (server state)
UI components:   React Native Paper 5 (base) + custom design system
Charts:          Victory Native XL (runs on UI thread via Reanimated)
Animations:      Reanimated 3 + Gesture Handler 2
Maps:            react-native-maps (Apple Maps iOS, Google Maps Android)
GPS:             expo-location (foreground + background)
Camera:          expo-camera (barcode scan, progress photos)
Health:          expo-health (HealthKit iOS, Health Connect Android)
Notifications:   expo-notifications (push, local, scheduled)
Storage:         expo-secure-store (sensitive), AsyncStorage (general cache)
Forms:           React Hook Form + Zod (validation)
Payments:        react-native-purchases (RevenueCat SDK)

## 2.2 Web application
Framework:       Next.js 15 (App Router, React Server Components)
Language:        TypeScript 5.6 strict
Styling:         Tailwind CSS v4 + shadcn/ui components
State:           Zustand + TanStack Query (same stores as mobile where possible)
Auth:            Supabase Auth SSR helpers (@supabase/ssr)
Deployment:      Vercel (automatic deploys on push to main)

## 2.3 Desktop application
Framework:       Tauri v2 (wraps Next.js web app)
Targets:         Windows (.exe installer), macOS (.dmg), Linux (.AppImage)
Build:           GitHub Actions matrix build (Windows, macOS, Linux runners)
Distribution:    GitHub Releases (direct download), future: Winget, Homebrew

## 2.4 Backend and database
Primary BaaS:    Supabase (PostgreSQL 15 + PostgREST + GoTrue + Realtime)
Database:        PostgreSQL 15.x via Supabase (managed, no self-hosted)
Auth:            Supabase GoTrue (email, Google OAuth, Apple OAuth, phone OTP)
File storage:    Supabase Storage (profile photos, progress photos, avatars)
Media storage:   Cloudflare R2 (workout videos, large exports -- zero egress fees)
Video delivery:  Cloudflare Stream (HLS adaptive bitrate for workout videos)
Cache layer:     Upstash Redis (serverless Redis -- rate limiting, AI response cache)
Edge functions:  Supabase Edge Functions (Deno runtime -- webhooks, AI orchestration)
Custom API:      Node.js 22 + Fastify 5 on Railway (complex business logic, v2+)
CDN:             Cloudflare (global, in front of all static assets)
Search:          PostgreSQL full-text search (FTS) for food and exercise database
Vectors:         pgvector extension in Supabase (AI embeddings for semantic search)

## 2.5 AI and intelligence
Primary model:   Claude claude-sonnet-4-5 (Anthropic API) -- AI coach chat and analysis
Fast model:      claude-haiku-4-5-20251001 -- quick suggestions, autocomplete food
Embeddings:      text-embedding-3-small (OpenAI) via Supabase pgvector
Context window:  Always include last 7 days of user data in system prompt
Caching:         Upstash Redis -- cache identical AI responses for 24 hours
Cost control:    Rate limit AI requests per user tier (Free: 5/day, Pro: 50/day, Elite: unlimited)

## 2.6 Payments
Nepal (primary): eSewa REST API v2 + Khalti REST API (web redirect flow)
Mobile IAP:      RevenueCat (handles App Store and Play Store billing, receipt validation)
International:   Stripe (web subscriptions for non-Nepal users, v2+)
Commissions:     Trainer marketplace -- 15% platform fee, 85% trainer payout
Payouts:         eSewa merchant API / Khalti merchant API (Nepal), Stripe Connect (international)

## 2.7 DevOps and infrastructure
Version control: Git + GitHub (private repository)
CI/CD:           GitHub Actions
  -- On PR:      ESLint, TypeScript check, Vitest unit tests, Expo build check
  -- On main:    Vercel deploy (web), Expo EAS update (mobile OTA), Sentry release
  -- On tag:     EAS Build + Submit to App Store and Play Store, Tauri desktop build
Mobile builds:   Expo EAS Build (cloud builds -- no local Xcode needed for Android)
OTA updates:     Expo EAS Update (push JS updates without App Store review)
Error tracking:  Sentry (React Native SDK + Next.js SDK -- source maps uploaded on deploy)
Analytics:       PostHog (product analytics, feature flags, session replay)
Monitoring:      Upstash Redis metrics + Supabase dashboard + Railway metrics
Secrets:         GitHub Actions secrets + Expo EAS secrets (never in .env committed)

## 2.8 Developer tooling
IDE:             Cursor (primary) -- this file provides AI context
AI assistant:    Claude claude-sonnet-4-5 via Claude.ai (architecture, complex debugging)
Testing:         Vitest (unit) + React Native Testing Library (component) + Maestro (E2E)
API testing:     Bruno (open-source Postman alternative, collections committed to repo)
Linting:         ESLint 9 (flat config) + Prettier 3
Git hooks:       Lefthook (pre-commit: lint + type-check, commit-msg: conventional commits)
Commit format:   Conventional Commits (feat, fix, chore, docs, refactor, test, perf)


# -----------------------------------------------------------------------------
# SECTION 3: SYSTEM ARCHITECTURE
# -----------------------------------------------------------------------------

## 3.1 Architecture pattern
Pattern:         Layered architecture with clear boundaries
Mobile:          Screens -> Hooks -> Services -> Supabase client
Web:             Pages/Layouts -> Components -> Server Actions -> Supabase SSR client
Backend:         Routes -> Controllers -> Services -> Repository -> Database

## 3.2 Data flow
Client request   -> TanStack Query (cache check)
Cache miss       -> Supabase PostgREST (direct from client, RLS enforced)
Complex ops      -> Supabase Edge Function (Deno) or Node.js API (Railway)
AI requests      -> Edge Function -> Upstash cache check -> Anthropic API
Real-time        -> Supabase Realtime (PostgreSQL logical replication via WebSocket)

## 3.3 Load balancing and scaling strategy
Supabase:        Managed -- pgBouncer connection pooling built in (pool mode: transaction)
                 Connection limit: 15 direct, 200 pooled (free tier)
                 Scale path: Supabase Pro (dedicated resources) at 10K+ MAU
Vercel:          Automatic global edge network -- no configuration required
                 Serverless functions auto-scale to zero, cold starts mitigated by edge runtime
Railway:         Vertical scale (CPU/RAM) via dashboard, horizontal via replicas (v2+)
                 Health check endpoint: GET /health -- Railway auto-restarts on failure
Redis:           Upstash serverless -- no connection management, auto-scale
                 Rate limiting pattern: sliding window per user ID + IP
Cloudflare:      CDN caches static assets and R2 media globally
                 R2 zero egress -- no bandwidth cost for video delivery
Database:        Read replicas (Supabase Pro) for analytics queries (v2+)
                 Separate read/write paths via SUPABASE_READ_URL env var

## 3.4 Database connection strategy
ORM:             None -- raw Supabase client (PostgREST) for client-side
                 Raw SQL via Supabase Edge Functions for complex server queries
Pooling:         pgBouncer (Supabase managed) -- always use pooled connection string
                 Direct connection only for migrations (prisma migrate, supabase db push)
Migrations:      Supabase CLI (supabase db diff -> supabase db push)
                 All migrations in /supabase/migrations/ -- committed to repo
Indexes:         Declared in migration files -- never added ad hoc
                 Required: every foreign key, every column used in WHERE or ORDER BY

## 3.5 Caching strategy
Layer 1:         TanStack Query client-side cache (stale-while-revalidate)
                 staleTime: 5 minutes for user data, 1 hour for exercise/food library
Layer 2:         Upstash Redis server-side cache
                 AI responses: 24-hour TTL keyed by (user_id + prompt_hash)
                 Food search results: 1-hour TTL keyed by search query
                 Leaderboards: 5-minute TTL (acceptable staleness for ranking)
Layer 3:         Cloudflare CDN for static assets (1-year cache, content-hash filenames)
Layer 4:         AsyncStorage on device for offline support
                 Workout sessions, food log, user profile cached locally

## 3.6 Security architecture
Authentication:  Supabase GoTrue -- JWT tokens (1-hour expiry, 30-day refresh)
Authorization:   Row Level Security (RLS) on every table -- no exceptions
                 RLS policies in /supabase/migrations/ -- reviewed before every deploy
API security:    Rate limiting via Upstash Redis on all Edge Functions
                 100 requests/minute per authenticated user
                 10 requests/minute per unauthenticated IP
Secrets:         All secrets in environment variables -- never in source code
                 Required: SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_KEY,
                           ANTHROPIC_API_KEY, REVENUECAT_API_KEY, UPSTASH_URL,
                           UPSTASH_TOKEN, ESEWA_SECRET, KHALTI_SECRET
Encryption:      DMs: AES-256-GCM client-side encryption (keys never leave device)
                 Progress photos: Supabase Storage private buckets (signed URLs, 1-hour expiry)
                 All transit: TLS 1.3 minimum
CORS:            Explicit allowlist -- no wildcard origins in production
Content:         Helmet.js on Node.js API, security headers via Vercel config
Audit log:       All write operations logged to audit_log table (user_id, action, timestamp, ip)


# -----------------------------------------------------------------------------
# SECTION 4: DATABASE SCHEMA
# -----------------------------------------------------------------------------

## 4.1 Core tables (always reference these for queries)

users
  id              uuid PRIMARY KEY DEFAULT gen_random_uuid()
  email           text UNIQUE NOT NULL
  username        text UNIQUE NOT NULL
  display_name    text
  avatar_url      text
  date_of_birth   date
  gender          text CHECK (gender IN ('male','female','other','prefer_not_to_say'))
  height_cm       numeric(5,1)
  weight_kg       numeric(5,1)
  goal            text CHECK (goal IN ('lose_weight','build_muscle','run_faster','flexibility','general_health'))
  fitness_level   text CHECK (fitness_level IN ('beginner','intermediate','advanced'))
  activity_level  text CHECK (activity_level IN ('sedentary','lightly_active','moderately_active','very_active'))
  equipment       text[] DEFAULT '{}'
  language        text DEFAULT 'ne' CHECK (language IN ('ne','en'))
  units           text DEFAULT 'metric' CHECK (units IN ('metric','imperial'))
  tier            text DEFAULT 'free' CHECK (tier IN ('free','pro','elite'))
  stripe_id       text
  revenuecat_id   text
  timezone        text DEFAULT 'Asia/Kathmandu'
  onboarded_at    timestamptz
  created_at      timestamptz DEFAULT now()
  updated_at      timestamptz DEFAULT now()

workout_sessions
  id              uuid PRIMARY KEY DEFAULT gen_random_uuid()
  user_id         uuid REFERENCES users(id) ON DELETE CASCADE
  program_id      uuid REFERENCES programs(id) ON DELETE SET NULL
  name            text NOT NULL
  notes           text
  started_at      timestamptz NOT NULL
  completed_at    timestamptz
  duration_seconds integer
  total_volume_kg numeric(10,2)
  total_sets      integer DEFAULT 0
  calories_burned integer
  rpe_average     numeric(3,1)
  is_public       boolean DEFAULT false
  created_at      timestamptz DEFAULT now()

workout_sets
  id              uuid PRIMARY KEY DEFAULT gen_random_uuid()
  session_id      uuid REFERENCES workout_sessions(id) ON DELETE CASCADE
  exercise_id     uuid REFERENCES exercises(id) ON DELETE RESTRICT
  set_number      integer NOT NULL
  weight_kg       numeric(6,2)
  reps            integer
  duration_seconds integer
  distance_m      numeric(8,2)
  rpe             integer CHECK (rpe BETWEEN 1 AND 10)
  is_warmup       boolean DEFAULT false
  is_pr           boolean DEFAULT false
  logged_at       timestamptz DEFAULT now()

exercises
  id              uuid PRIMARY KEY DEFAULT gen_random_uuid()
  name            text NOT NULL
  name_ne         text
  category        text CHECK (category IN ('push','pull','legs','yoga','hiit','cardio','other'))
  muscle_group    text[] NOT NULL
  equipment       text[] DEFAULT '{}'
  difficulty      text CHECK (difficulty IN ('beginner','intermediate','advanced'))
  instructions    text
  instructions_ne text
  video_url       text
  thumbnail_url   text
  is_custom       boolean DEFAULT false
  created_by      uuid REFERENCES users(id) ON DELETE SET NULL
  created_at      timestamptz DEFAULT now()

programs
  id              uuid PRIMARY KEY DEFAULT gen_random_uuid()
  name            text NOT NULL
  name_ne         text
  description     text
  category        text
  duration_weeks  integer
  days_per_week   integer
  difficulty      text
  equipment       text[]
  is_official     boolean DEFAULT false
  created_by      uuid REFERENCES users(id) ON DELETE SET NULL
  created_at      timestamptz DEFAULT now()

meal_logs
  id              uuid PRIMARY KEY DEFAULT gen_random_uuid()
  user_id         uuid REFERENCES users(id) ON DELETE CASCADE
  food_item_id    uuid REFERENCES food_items(id) ON DELETE RESTRICT
  meal_type       text CHECK (meal_type IN ('breakfast','lunch','dinner','snack'))
  serving_size    numeric(8,2) NOT NULL
  serving_unit    text NOT NULL
  calories        integer NOT NULL
  protein_g       numeric(6,2)
  carbs_g         numeric(6,2)
  fat_g           numeric(6,2)
  fibre_g         numeric(6,2)
  logged_at       timestamptz DEFAULT now()
  date            date NOT NULL DEFAULT CURRENT_DATE

food_items
  id              uuid PRIMARY KEY DEFAULT gen_random_uuid()
  name            text NOT NULL
  name_ne         text
  brand           text
  barcode         text UNIQUE
  is_nepali       boolean DEFAULT false
  calories_per_100g integer NOT NULL
  protein_per_100g  numeric(6,2)
  carbs_per_100g    numeric(6,2)
  fat_per_100g      numeric(6,2)
  fibre_per_100g    numeric(6,2)
  serving_size    numeric(8,2)
  serving_unit    text
  is_verified     boolean DEFAULT false
  submitted_by    uuid REFERENCES users(id) ON DELETE SET NULL
  created_at      timestamptz DEFAULT now()

run_sessions
  id              uuid PRIMARY KEY DEFAULT gen_random_uuid()
  user_id         uuid REFERENCES users(id) ON DELETE CASCADE
  activity_type   text CHECK (activity_type IN ('run','walk','hike','cycle'))
  distance_m      numeric(10,2) NOT NULL
  duration_seconds integer NOT NULL
  avg_pace_spm    integer
  avg_speed_mps   numeric(6,3)
  avg_hr_bpm      integer
  max_hr_bpm      integer
  calories_burned integer
  elevation_gain_m numeric(8,2)
  route_geojson   jsonb
  splits          jsonb
  started_at      timestamptz NOT NULL
  is_public       boolean DEFAULT false
  created_at      timestamptz DEFAULT now()

sleep_logs
  id              uuid PRIMARY KEY DEFAULT gen_random_uuid()
  user_id         uuid REFERENCES users(id) ON DELETE CASCADE
  bedtime         timestamptz NOT NULL
  wake_time       timestamptz NOT NULL
  duration_minutes integer NOT NULL
  quality_rating  integer CHECK (quality_rating BETWEEN 1 AND 5)
  sleep_score     integer CHECK (sleep_score BETWEEN 0 AND 100)
  deep_minutes    integer
  rem_minutes     integer
  light_minutes   integer
  awake_minutes   integer
  notes           text
  source          text DEFAULT 'manual' CHECK (source IN ('manual','apple_health','google_health','garmin'))
  date            date NOT NULL DEFAULT CURRENT_DATE
  created_at      timestamptz DEFAULT now()

body_metrics
  id              uuid PRIMARY KEY DEFAULT gen_random_uuid()
  user_id         uuid REFERENCES users(id) ON DELETE CASCADE
  weight_kg       numeric(5,2)
  body_fat_pct    numeric(4,2)
  chest_cm        numeric(5,2)
  waist_cm        numeric(5,2)
  hips_cm         numeric(5,2)
  arms_cm         numeric(5,2)
  thighs_cm       numeric(5,2)
  neck_cm         numeric(5,2)
  photo_url       text
  notes           text
  logged_at       timestamptz DEFAULT now()
  date            date NOT NULL DEFAULT CURRENT_DATE

personal_records
  id              uuid PRIMARY KEY DEFAULT gen_random_uuid()
  user_id         uuid REFERENCES users(id) ON DELETE CASCADE
  exercise_id     uuid REFERENCES exercises(id) ON DELETE CASCADE
  record_type     text CHECK (record_type IN ('max_weight','max_reps','max_volume','max_distance','fastest_pace'))
  value           numeric(10,3) NOT NULL
  unit            text NOT NULL
  achieved_at     timestamptz NOT NULL
  session_id      uuid REFERENCES workout_sessions(id) ON DELETE SET NULL
  UNIQUE (user_id, exercise_id, record_type)

follows
  follower_id     uuid REFERENCES users(id) ON DELETE CASCADE
  following_id    uuid REFERENCES users(id) ON DELETE CASCADE
  created_at      timestamptz DEFAULT now()
  PRIMARY KEY (follower_id, following_id)
  CHECK (follower_id != following_id)

kudos
  id              uuid PRIMARY KEY DEFAULT gen_random_uuid()
  giver_id        uuid REFERENCES users(id) ON DELETE CASCADE
  activity_type   text CHECK (activity_type IN ('workout','run','pr'))
  activity_id     uuid NOT NULL
  created_at      timestamptz DEFAULT now()
  UNIQUE (giver_id, activity_type, activity_id)

messages
  id              uuid PRIMARY KEY DEFAULT gen_random_uuid()
  conversation_id uuid REFERENCES conversations(id) ON DELETE CASCADE
  sender_id       uuid REFERENCES users(id) ON DELETE CASCADE
  content_encrypted text NOT NULL
  content_iv      text NOT NULL
  read_at         timestamptz
  deleted_at      timestamptz
  created_at      timestamptz DEFAULT now()

ai_conversations
  id              uuid PRIMARY KEY DEFAULT gen_random_uuid()
  user_id         uuid REFERENCES users(id) ON DELETE CASCADE
  messages        jsonb NOT NULL DEFAULT '[]'
  context_snapshot jsonb
  created_at      timestamptz DEFAULT now()
  updated_at      timestamptz DEFAULT now()

subscriptions
  id              uuid PRIMARY KEY DEFAULT gen_random_uuid()
  user_id         uuid REFERENCES users(id) ON DELETE CASCADE UNIQUE
  tier            text NOT NULL
  status          text CHECK (status IN ('active','cancelled','expired','trial','paused'))
  platform        text CHECK (platform IN ('ios','android','web','esewa','khalti'))
  external_id     text
  trial_ends_at   timestamptz
  current_period_start timestamptz
  current_period_end   timestamptz
  cancelled_at    timestamptz
  created_at      timestamptz DEFAULT now()
  updated_at      timestamptz DEFAULT now()

promo_codes
  id              uuid PRIMARY KEY DEFAULT gen_random_uuid()
  code            text UNIQUE NOT NULL
  discount_type   text CHECK (discount_type IN ('percent','fixed_npr','free_months'))
  discount_value  numeric(8,2) NOT NULL
  applicable_tier text[]
  max_uses        integer
  uses_count      integer DEFAULT 0
  per_user_limit  integer DEFAULT 1
  expires_at      timestamptz
  created_by      uuid REFERENCES users(id)
  is_active       boolean DEFAULT true
  created_at      timestamptz DEFAULT now()

audit_log
  id              bigserial PRIMARY KEY
  user_id         uuid REFERENCES users(id) ON DELETE SET NULL
  action          text NOT NULL
  table_name      text
  record_id       uuid
  old_values      jsonb
  new_values      jsonb
  ip_address      inet
  user_agent      text
  created_at      timestamptz DEFAULT now()

## 4.2 Required indexes (never skip these)
CREATE INDEX ON workout_sessions (user_id, started_at DESC);
CREATE INDEX ON workout_sets (session_id);
CREATE INDEX ON workout_sets (exercise_id, user_id);
CREATE INDEX ON meal_logs (user_id, date DESC);
CREATE INDEX ON run_sessions (user_id, started_at DESC);
CREATE INDEX ON sleep_logs (user_id, date DESC);
CREATE INDEX ON body_metrics (user_id, date DESC);
CREATE INDEX ON personal_records (user_id, exercise_id);
CREATE INDEX ON follows (follower_id);
CREATE INDEX ON follows (following_id);
CREATE INDEX ON messages (conversation_id, created_at DESC);
CREATE INDEX ON food_items (barcode) WHERE barcode IS NOT NULL;
CREATE INDEX ON food_items (is_nepali) WHERE is_nepali = true;
CREATE INDEX ON food_items USING gin(to_tsvector('english', name));
CREATE INDEX ON exercises USING gin(to_tsvector('english', name));

## 4.3 RLS policy pattern (enforce on every table)
-- Every table must have RLS enabled
ALTER TABLE [table] ENABLE ROW LEVEL SECURITY;

-- Standard user-owned data policy
CREATE POLICY "users_own_data" ON [table]
  USING (auth.uid() = user_id);

CREATE POLICY "users_insert_own" ON [table]
  FOR INSERT WITH CHECK (auth.uid() = user_id);

CREATE POLICY "users_update_own" ON [table]
  FOR UPDATE USING (auth.uid() = user_id);

-- Public read policy (for activities marked is_public)
CREATE POLICY "public_activities_readable" ON workout_sessions
  FOR SELECT USING (is_public = true OR auth.uid() = user_id);


